APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Опционально: дополнительный домен для субдоменов. По умолчанию учтены gg-hub.local и gg-hub.ru
# APP_DOMAIN=gg-hub.ru

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Канал, через который отправляются уведомления (см. config/logging.php → "channels").
# По умолчанию — "notification-hub" (HTTP в notification-gg-hub).
# Чтобы быстро переключиться обратно на прямой Telegram-канал, поменяйте на "telegram"
# (или любой другой объявленный канал).
NOTIFICATIONS_LOG_CHANNEL=notification-hub

# Уведомления через notification-gg-hub (если токен пуст — отправка отключена)
NOTIFICATION_HUB_URL=https://notification-gg-hub.ru
NOTIFICATION_HUB_INGRESS_TOKEN=
# NOTIFICATION_HUB_TIMEOUT=10

# Прямой канал Telegram (используется только если NOTIFICATIONS_LOG_CHANNEL=telegram).
# Если пусто — отправка отключена.
# TELEGRAM_LOGGER_CHAT_ID=
# TELEGRAM_LOGGER_TOKEN=

# URL фронтенда для ссылок в уведомлениях (по умолчанию APP_URL)
# FRONTEND_URL=http://localhost

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=src
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Домен cookie: если не задан, берётся из APP_URL (например .gg-hub.local) — одна авторизация для домена и всех субдоменов
# SESSION_DOMAIN=.gg-hub.local

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Для production: MAIL_MAILER=smtp с docker-mailserver
# Для разработки: MAIL_MAILER=log (письма пишутся в storage/logs)
MAIL_MAILER=log
MAIL_HOST=mailserver
MAIL_PORT=587
MAIL_USERNAME=noreply@gg-hub.ru
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@gg-hub.ru"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# OAuth (Socialite)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI="${APP_URL}/auth/yandex/callback"

VKONTAKTE_CLIENT_ID=
VKONTAKTE_CLIENT_SECRET=
VKONTAKTE_REDIRECT_URI="${APP_URL}/auth/vkontakte/callback"

VITE_APP_NAME="${APP_NAME}"
