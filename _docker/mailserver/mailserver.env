# docker-mailserver environment configuration
# https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/

OVERRIDE_HOSTNAME=mail778.gg-hub.ru

ENABLE_CLAMAV=0
ENABLE_RSPAMD=1
ENABLE_SPAMASSASSIN=0
ENABLE_AMAVIS=0
ENABLE_FAIL2BAN=1
ENABLE_POSTGREY=0
ENABLE_QUOTAS=1

SSL_TYPE=letsencrypt
PERMIT_DOCKER=network
ONE_DIR=1
LOG_LEVEL=info

POSTFIX_MESSAGE_SIZE_LIMIT=26214400
ENABLE_IMAP=1
ENABLE_POP3=0

SPOOF_PROTECTION=1
ENABLE_SRS=0
ENABLE_OPENDKIM=1
ENABLE_OPENDMARC=1

POSTMASTER_ADDRESS=postmaster@gg-hub.ru
