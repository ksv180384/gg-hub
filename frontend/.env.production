# Абсолютный URL для SEO (canonical, Open Graph, preload LCP). Без слэша в конце.
# Должен совпадать с основным доменом в index.html / sitemap / редиректах nginx (без www или с www — единообразно).
VITE_SITE_URL=https://gg-hub.ru
# Опционально: абсолютный URL изображения 1200×630 для соцсетей
# VITE_OG_IMAGE_URL=https://gg-hub.ru/og-image.png
# Логотип для JSON-LD Organization (лучше PNG 512×512), иначе подставится /favicon.ico
# VITE_ORGANIZATION_LOGO_URL=https://gg-hub.ru/logo-512.png
# Через запятую: соцсети и внешние профили для sameAs
# VITE_ORG_SAME_AS=https://vk.com/...
# VITE_ORG_CONTACT_EMAIL=support@gg-hub.ru

VITE_APP_HOST=gg-hub.ru
VITE_APP_HMR_PORT=80
VITE_APP_API_PORT=80
# Рулетка: обычно не нужен — тот же домен + /socket.io (см. nginx). Иначе явный URL сокета:
# VITE_SOCKET_URL=https://gg-hub.ru:3007
